{
  "addr":        "127.0.0.1:8080",
  "data_dir":    "~/.tscriber/sessions",
  "threads":     0,

  "whisper_bin": "third_party/whisper.cpp/build/bin/whisper-cli",
  "model":       "models/ggml-large-v3-turbo-q5_0.bin",
  "vad_model":   "models/ggml-silero-v5.1.2.bin",

